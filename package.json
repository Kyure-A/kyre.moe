{
  "name": "kyre.moe",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "prepare": "panda codegen",
    "prelint": "panda codegen",
    "prebuild": "panda codegen",
    "prestorybook": "panda codegen",
    "prebuild-storybook": "panda codegen",
    "panda": "panda codegen",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "storybook": "storybook dev -p ${STORYBOOK_PORT:-7006}",
    "storybook:reset-cache": "rm -rf node_modules/.cache/storybook",
    "build-storybook": "storybook build",
    "content": "node scripts/export-org.mjs && node scripts/copy-blog-images.mjs",
    "fix:ogp-export": "node scripts/fix-ogp-export.mjs",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "lint:actions": "actionlint",
    "security:semgrep": "semgrep scan --config p/default --error --metrics=off ."
  },
  "dependencies": {
    "@react-spring/web": "^10.0.3",
    "@vscode/markdown-it-katex": "^1.1.2",
    "budoux": "0.8.0",
    "gray-matter": "^4.0.3",
    "gsap": "^3.12.7",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.38",
    "markdown-exit": "^1.0.0-beta.7",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-budoux": "^1.0.6",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-github-alerts": "^1.0.0",
    "markdown-it-magic-link": "^0.1.4",
    "markdown-it-task-lists": "^2.1.1",
    "markdown-it-toc-done-right": "^4.2.0",
    "next": "16.2.6",
    "next-view-transitions": "^0.3.5",
    "ogl": "^1.0.11",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-icons": "^5.6.0",
    "three": "^0.167.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@pandacss/dev": "^1.11.3",
    "@testing-library/dom": "10.4.0",
    "@storybook/addon-a11y": "^10.3.0",
    "@storybook/nextjs-vite": "10.2.8",
    "@storybook/react": "10.2.8",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "20.19.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/three": "^0.175.0",
    "storybook": "10.3.1",
    "typescript": "^5.8.3",
    "vite": "7.3.5"
  },
  "pnpm": {
    "overrides": {
      "budoux": "^0.7.0"
    }
  }
