    "next-view-transitions": "^0.3.5",
    "ogl": "^1.0.11",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-icons": "^5.6.0",
    "sanitize-html": "^2.17.5",
    "three": "^0.185.1",
    "uniorg-parse": "^3.2.2"
