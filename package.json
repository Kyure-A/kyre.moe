    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/sanitize-html": "^2.16.1",
    "@types/three": "^0.185.1",
    "storybook": "10.3.1",
    "typescript": "^5.8.3",
    "vite": "7.3.5"
